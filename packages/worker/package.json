{
  "name": "outpost-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker control plane for outpost: webhook ingestion, sandbox orchestration, dashboard API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply outpost-lifecycle --local"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.1.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
