{
  "name": "lantern",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "OpenCode plugin: receive GitHub webhooks and dispatch them to OpenCode agent sessions",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "echo 'lantern ships raw TS — no build step needed'"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "@sentry/bun": "^9.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.1.1"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.30",
