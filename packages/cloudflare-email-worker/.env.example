# Cloudflare Email Worker — local dev configuration.
#
# Copy this file to `.env` (gitignored) and fill in your values:
#   cp .env.example .env
#
# Wrangler v4 reads `.env` automatically when running `wrangler dev`
# and exposes its keys as worker bindings (env.WEBHOOK_URL, etc.).
#
# These values are LOCAL-ONLY. For production deploys, set both
# variables in the Cloudflare dashboard:
#   Workers & Pages → opencode-email-worker → Settings →
#   Variables and Secrets → Add (type: Plaintext)
#
# Public URL of the openhealer plugin's email endpoint. Must be
# reachable from Cloudflare's worker network (so a public ingress, not
# private-only).
WEBHOOK_URL="https://your-opencode-host.example.com:5050/webhooks/email"

# Optional. If set, every inbound email is forwarded here verbatim
# (DKIM-preserving via Cloudflare's message.forward()). The address
# MUST be verified in Cloudflare Email Routing → Destination addresses
# first, otherwise the forward throws on every email (the worker
# catches and continues, but you'll see noisy logs).
#
# Leave the line commented out to skip forwarding entirely.
# FORWARD_TO="you@yourdomain.com"

# Optional. Comma-separated list of email addresses that are treated
# exactly like FORWARD_TO: emails from these senders are NOT forwarded
# back (no message.forward()) and are auto-allowed through the webhook
# gate to reach the agent. Useful for additional operator inboxes.
#
# For production, set via: wrangler secret put ALLOWED_EMAILS
# ALLOWED_EMAILS="alice@example.com,bob@example.com"
