{
  "name": "opentower",
  "version": "0.1.3",
  "type": "module",
  "license": "MIT",
  "description": "OpenCode plugin: receive GitHub webhooks and dispatch them to OpenCode agent sessions",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun run build:dashboard && bun run build:copy",
    "build:dashboard": "bun run --cwd ../dashboard build",
    "build:copy": "rm -rf ./public && cp -r ../dashboard/dist ./public",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.75",
    "@sentry/bun": "^9.0.0",
    "ai": "^6.0.175",
    "hono": "^4.0.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.1.1"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.30",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "files": [
    "src/",
    "public/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MathurAditya724/outpost.git",
    "directory": "packages/opentower"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "opencode",
    "plugin",
    "github",
    "webhook",
    "agent",
    "automation"
  ],
  "author": "Aditya Mathur"
}
