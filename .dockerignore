# VCS
.git
.gitignore

# Docs / meta (not needed in the image)
README.md
LICENSE

# Local-only env files (never bake into image)
.env
**/.env
**/.env.*

# Editor / OS noise
.idea
.vscode
*.swp
*.swo
**/.DS_Store
Thumbs.db

# Build artifacts / logs
**/node_modules
*.log

# Root workspace files — not used inside the image (the Dockerfile
# copies opencode-config-package.json and opencode-config-bun.lock instead).
package.json
bun.lock
biome.json

# Cloudflare Email Worker — deployed independently with `wrangler deploy`,
# not needed inside the runtime image.
packages/cloudflare-email-worker
