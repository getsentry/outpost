{
  "name": "@jared/server",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:cleanup:dev": "tsx ./scripts/cleanup.ts",
    "db:migrate:dev": "wrangler d1 migrations apply --local jared",
    "db:migrate:prod": "NODE_ENV=production wrangler d1 migrations apply --remote jared",
    "db:studio:dev": "drizzle-kit studio",
    "db:studio:prod": "NODE_ENV=production drizzle-kit studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@cloudflare/containers": "^0.3.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hono/standard-validator": "^0.2.2",
    "@hono/structured-logger": "^0.1.0",
    "@jared/utils": "workspace:*",
    "@jared/validations": "workspace:*",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-methods": "^6.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/cloudflare": "^10.56.0",
    "@sentry/react": "^10.56.0",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@tanstack/react-query": "^5.101.0",
    "better-auth": "^1.6.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "hono-openapi": "^1.3.0",
    "nanoid": "^5.1.11",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/sandbox": "^0.12.0",
    "@cloudflare/vite-plugin": "^1.40.0",
    "@cloudflare/workers-types": "^4.20260605.1",
    "@libsql/client": "^0.17.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}
